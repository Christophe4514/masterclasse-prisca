# mahisha payment — https://dashboard.mahisha.com/settings/api-keys
MAHISHA_SECRET_KEY=
MAHISHA_PUBLIC_KEY=
MAHISHA_CALLBACK_URL=http://localhost:3000/api/payment-webhook

# Admin — mot de passe de connexion + secret pour signer le cookie de session
ADMIN_PASSWORD=
ADMIN_SECRET=

# Marketing / pages publiques (footer, succès checkout)
