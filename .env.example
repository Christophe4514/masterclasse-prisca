# Admin — mot de passe de connexion + secret pour signer le cookie de session
ADMIN_PASSWORD=admin
ADMIN_SECRET=admin

# --- MaishaPay Checkout ---
# 0 = sandbox (clés de test), 1 = production (clés live). Doit correspondre aux clés, sinon « Compte not found ».
# Si omis : détection via la clé publique (ex. MP-LIVEPK… → production).
MAISHAPAY_GATEWAY_MODE=1
MAISHAPAY_PUBLIC_API_KEY=
MAISHAPAY_SECRET_API_KEY=
# URL unique du checkout (optionnel — défaut : marchand.maishapay.online …/checkout)
# MAISHAPAY_CHECKOUT_URL=https://marchand.maishapay.online/payment/vers1.0/merchant/checkout

# Webhook interne (tests / autres PSP) — header x-webhook-secret
PAYMENT_WEBHOOK_SECRET=admin

# URL publique du site (SEO, liens dans e-mails, callback MaishaPay)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=resend
RESEND_FROM_EMAIL=onboarding@resend.dev

# Lien de téléchargement / accès masterclass après paiement (utilisé par le webhook)
DIGITAL_DELIVERY_URL=https://masterclassprisca.vercel.app/
