# URL publique du site (SEO, liens dans e-mails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=""
RESEND_FROM_EMAIL=priscamakila@kimengin.com

# Lien de téléchargement / accès masterclass après paiement (utilisé par le webhook)
